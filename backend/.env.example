# Lyrica 3 Pro — Backend Environment
# Copy this to backend/.env and fill in real values

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: spin up MongoDB with `docker run -d -p 27017:27017 mongo`
# or use MongoDB Atlas free tier: https://cloud.mongodb.com
MONGO_URL=mongodb://localhost:27017
DB_NAME=lyrica3_dev

# ── Auth ──────────────────────────────────────────────────────────────────────
# Change this before any real usage — use a random 32-char string
JWT_SECRET=dev_secret_change_me_before_prod

# ── AI / LLM ──────────────────────────────────────────────────────────────────
# Emergent / Claude API key (used for generation)
EMERGENT_LLM_KEY=

# Google Gemini / Vertex AI
GOOGLE_API_KEY=

# Replicate (optional — for Demucs stem separation)
REPLICATE_API_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Local dev: allow all origins
CORS_ORIGINS=*

# ── Redis (optional — falls back to in-memory if not set) ────────────────────
# REDIS_URL=redis://localhost:6379

# ── File TTLs ─────────────────────────────────────────────────────────────────
VOICE_TTL_MIN=240
UPLOAD_TTL_MIN=1440

# ── Features ──────────────────────────────────────────────────────────────────
DEMUCS_ENABLED=false
