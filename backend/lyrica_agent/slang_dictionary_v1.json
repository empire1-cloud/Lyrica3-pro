  "processing_rules": {
    "vowel_shifts": {
      "description": "How mouth shape changes pronunciation",
      "examples": {
        "open_o_shift": "home /hoʊm/ → /hɔːm/ (darker, warmer)",
        "flattened_i": "right /raɪt/ → /raːt/ (less bright, more cool)",
        "dropped_r": "brother /ˈbrʌðər/ → /ˈbrɔːðə/ (softened ending)"
      }
    },
    "consonant_texture": {
      "description": "How tongue hits teeth/palate",
      "examples": {
        "t_glottalization": "Insert <glottal_stop_hard> for words like 'better', 'right'",
        "d_softening": "Reduce transient energy 40% for final 'D' sounds",
        "s_hiss_reduction": "Apply de-esser @ 6kHz with slow release"
      }
    },
    "rhythmic_compression": {
      "description": "How syllables are squeezed/stretched",
      "examples": {
        "syllable_merge": "2 syllables → 1 syllable (wanna, gonna, outta)",
        "duration_compression": "Reduce duration 30-40% for merged syllables",
        "timing_offset": "Apply +15-25ms late-pocket timing for swagger"
      }
    }
  },
