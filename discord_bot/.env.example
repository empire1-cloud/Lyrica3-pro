# Lyrica 3 Pro — Discord Bot Environment
# Copy this to discord_bot/.env and fill in real values

# ── Discord App credentials ───────────────────────────────────────────────────
# Create app at https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
DISCORD_APP_ID=
DISCORD_PUBLIC_KEY=

# ── Guild ID (optional — for instant dev command registration) ────────────────
# Set to your test server ID to register commands instantly instead of ~1hr global
# DISCORD_GUILD_ID=

# ── Lyrica backend ────────────────────────────────────────────────────────────
EMPIRE1_API_URL=http://localhost:8001
EMPIRE1_PUBLIC_URL=http://localhost:3000
EMPIRE1_BOT_HANDLE=discord.lyrica3
EMPIRE1_BOT_PASS=discord_bot_sovereign_7f
