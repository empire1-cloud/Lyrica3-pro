# Lyrica 3 Pro — Frontend Environment
# Copy this to frontend/.env.local and fill in real values

# ── Backend URL ───────────────────────────────────────────────────────────────
# Local dev: run backend with `uvicorn server:app --reload --port 8001`
# The frontend auto-requests `/api/auth/demo` when backend DEMO_MODE=true.
REACT_APP_BACKEND_URL=http://localhost:8001

# ── Google GenAI (optional — for Lyria 3 orchestrator mode) ──────────────────
# REACT_APP_GEMINI_API_KEY=
